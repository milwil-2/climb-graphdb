# ── Neo4j Aura ────────────────────────────────────────────────────────────────
# Connection URI for your Aura instance (neo4j+s:// for encrypted).
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io

# NOTE: Aura username is the INSTANCE ID, not the string "neo4j".
NEO4J_USER=<instance-id>

# Aura instance password (generated at instance creation time).
NEO4J_PASSWORD=

# ── Upstream Supabase (READ-ONLY) ─────────────────────────────────────────────
# MUST be a READ-ONLY role on the climbing-elo Supabase DB.
# Never use the postgres superuser or a role with write privileges here.
DATABASE_URL=postgresql://<readonly_user>:<pw>@<host>.pooler.supabase.com:5432/postgres

# ── LLM / enrichment ─────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Ingest endpoint guard ─────────────────────────────────────────────────────
# Local-only bearer token protecting /ingest.
# When this variable is UNSET in the cloud environment, the /ingest route is
# automatically disabled (fail-safe default).
INGEST_API_KEY=

# ── News enrichment ───────────────────────────────────────────────────────────
NEWS_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:8000
